# ----------------------------------------------------------------------------
# Configuration SERVEUR Appwrite — utilisée uniquement par les scripts locaux
# (scripts/setup-appwrite.mjs). NE JAMAIS committer le fichier réel
# `.env.appwrite.local` : il contient une clé API serveur secrète.
#
#   cp .env.appwrite.local.example .env.appwrite.local
#   # puis renseignez APPWRITE_API_KEY depuis la console Appwrite
# ----------------------------------------------------------------------------
APPWRITE_ENDPOINT=https://fra.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=maison-saint-jules
APPWRITE_DATABASE_ID=maison_saint_jules_db
APPWRITE_API_KEY=__CLE_API_SERVEUR_SECRETE__
